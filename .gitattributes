# gitattributes for Unity proj
# Авто-определение кодировки и окончаний строк
* text=auto

# Unity YAML-файлы 
*.meta -text diff
*.unity -text diff
*.prefab -text diff
*.asset -text diff
*.mat -text diff
*.anim -text diff
*.controller -text diff
*.overrideController -text diff
*.physicMaterial -text diff
*.physicsMaterial2D -text diff
*.playable -text diff
*.mask -text diff
*.brush -text diff
*.flare -text diff
*.fontsettings -text diff
*.guiskin -text diff
*.giparams -text diff
*.renderTexture -text diff
*.spriteatlas -text diff
*.terrainlayer -text diff
*.mixer -text diff
*.shadervariants -text diff
*.unitypackage -text diff

